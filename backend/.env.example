# Copy to backend/.env — never commit .env
# Replace YOUR_PASSWORD with your RDS password (keep no spaces in the URL).

DATABASE_URL=postgresql+psycopg2://FinalProject5500:YOUR_PASSWORD@database-1.cijymfgets4w.us-east-1.rds.amazonaws.com:5432/housing_app?sslmode=require

# CORS: comma-separated origins for local dev + deployed frontend
